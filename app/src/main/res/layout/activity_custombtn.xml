<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbarSize="20dp"
        tools:context=".custombtn">


        <Button
            android:id="@+id/button"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="277dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="236dp"
            android:backgroundTint="#9C27B0"
            android:text="Order Now"
            android:textSize="24sp"
            app:cornerRadius="10dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.492"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="#FF0000" />

        <Button
            android:id="@+id/button3"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="184dp"
            android:text="Add to cart"
            android:textColor="#E91E63"
            android:textSize="24sp"
            app:icon="@drawable/ic_launcher1_foreground"
            app:iconSize="30dp"
            app:iconTint="#F40B0B"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button"
            app:strokeColor="#D3BF27"
            app:strokeWidth="3dp" />


        <Button
            android:id="@+id/button4"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="124dp"
            android:shadowColor="#FF9800"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="8"
            android:text="learn more"
            android:textAllCaps="false"
            android:textColor="#9C27B0"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button3"
            app:rippleColor="#9C27B0"
            app:shapeAppearance="@style/ShapeAppearance.MaterialComponents.LargeComponent" />

        <Button
            android:id="@+id/button5"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="120dp"
            android:backgroundTint="#009688"
            android:elevation="60dp"
            android:password="false"
            android:phoneNumber="false"
            android:scrollHorizontally="false"
            android:shadowColor="#B10A0A"
            android:shadowDx="20"
            android:shadowDy="20"
            android:shadowRadius="15"
            android:stateListAnimator="@null"
            android:text="GO"
            android:textAlignment="center"
            android:textAllCaps="false"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            app:cornerRadius="50dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button4" />


        <Switch
            android:id="@+id/switch1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="220dp"
            android:scaleX="2"
            android:scaleY="2"
            android:showText="true"
            android:textOff="OFF"
            android:textOn="ON"
            android:thumbTint="@color/thumb_color"
            android:trackTint="@color/track_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button5" />


        <!-- pour le defilement  -->
        <Space
            android:id="@+id/bottom_space"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            app:layout_constraintTop_toBottomOf="@+id/switch1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>


</ScrollView>


